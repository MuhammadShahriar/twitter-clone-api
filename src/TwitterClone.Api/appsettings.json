{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=twitterclone;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "twitter-clone-api",
    "Audience": "twitter-clone-clients",
    "ExpiryMinutes": 15
  },
  "RefreshToken": {
    "ExpiryDays": 7
  },
  "Cloudinary": {
    "CloudName": "",
    "ApiKey": "",
    "UploadFolder": "twitter-clone"
  },
  "AuthCookie": {
    "Name": "refresh_token",
    "Path": "/api/auth",
    "SameSite": "None",
    "Secure": true,
    "Domain": ""
  }
}
